{
  "name": "archivedesk-backend",
  "version": "0.1.0-alpha.2",
  "private": true,
  "type": "commonjs",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:frontend": "npm --prefix frontend run build",
    "start": "node dist/src/server.js",
    "start:prod": "set NODE_ENV=production&& set REQUIRE_HTTPS=false&& node dist/src/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "lint:frontend": "npm --prefix frontend run lint",
    "release:check": "npm run lint && npm test && npm run build && npm run lint:frontend && npm run build:frontend"
  },
  "dependencies": {
    "argon2": "^0.43.0",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "optionalDependencies": {
    "sharp": "^0.34.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
